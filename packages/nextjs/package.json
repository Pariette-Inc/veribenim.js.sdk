{
  "name": "@veribenim/nextjs",
  "version": "5.0.0",
  "description": "Veribenim KVKK/GDPR çerez onayı SDK - Next.js",
  "keywords": [
    "kvkk",
    "gdpr",
    "cookie",
    "consent",
    "veribenim",
    "nextjs",
    "next"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@veribenim/core": "workspace:*",
    "@veribenim/react": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "next": "^14.0.0",
    "react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
