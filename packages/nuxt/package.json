{
  "name": "@veribenim/nuxt",
  "version": "5.0.0",
  "description": "Veribenim KVKK/GDPR çerez onayı SDK - Nuxt 3 Modülü",
  "keywords": [
    "kvkk",
    "gdpr",
    "cookie",
    "consent",
    "veribenim",
    "nuxt",
    "nuxt3"
  ],
  "license": "MIT",
  "main": "./dist/module.cjs",
  "module": "./dist/module.mjs",
  "types": "./dist/types.d.ts",
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev": "nuxt-module-build build --stub",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nuxt/kit": "^3.0.0",
    "@veribenim/core": "workspace:*",
    "@veribenim/vue": "workspace:*"
  },
  "peerDependencies": {
    "nuxt": ">=3.0.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^0.8.0",
    "nuxt": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
