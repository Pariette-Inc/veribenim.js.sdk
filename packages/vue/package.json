{
  "name": "@veribenim/vue",
  "version": "4.0.0",
  "description": "Veribenim KVKK/GDPR çerez onayı SDK - Vue 3",
  "keywords": [
    "kvkk",
    "gdpr",
    "cookie",
    "consent",
    "veribenim",
    "vue",
    "vue3"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@veribenim/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@vue/runtime-core": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vue": "^3.0.0"
  }
}
